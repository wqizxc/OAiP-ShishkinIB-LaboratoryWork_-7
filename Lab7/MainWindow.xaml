<Window x:Class="Lab7.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Лабораторная работа №7 - Фигуры" 
        Height="700" Width="1200" 
        Loaded="Window_Loaded"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="320"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="280"/>
        </Grid.ColumnDefinitions>

        <!-- Левая панель - основные настройки -->
        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Background="#F5F5F5">
            <StackPanel Margin="8">

                <!-- Координаты -->
                <Border Background="White" Padding="6" Margin="0,0,0,6" BorderBrush="#DDD" BorderThickness="1" CornerRadius="3">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="8"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="X:" FontSize="11" FontWeight="Bold"/>
                            <TextBox x:Name="TxtX" Text="50" FontSize="11" Height="22" Margin="0,2,0,5"/>
                            <TextBlock Text="Ширина/Радиус:" FontSize="11" FontWeight="Bold"/>
                            <TextBox x:Name="TxtSize" Text="100" FontSize="11" Height="22" Margin="0,2,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Y:" FontSize="11" FontWeight="Bold"/>
                            <TextBox x:Name="TxtY" Text="50" FontSize="11" Height="22" Margin="0,2,0,5"/>
                            <TextBlock Text="Высота:" FontSize="11" FontWeight="Bold"/>
                            <TextBox x:Name="TxtHeight" Text="100" FontSize="11" Height="22" Margin="0,2,0,0"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Треугольник -->
                <Border Background="White" Padding="6" Margin="0,0,0,6" BorderBrush="#DDD" BorderThickness="1" CornerRadius="3">
                    <StackPanel>
                        <TextBlock Text="ТРЕУГОЛЬНИК" FontSize="11" FontWeight="Bold" Margin="0,0,0,4"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="4"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="4"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="В1" FontSize="10" HorizontalAlignment="Center"/>
                                <TextBox x:Name="TxtT1X" Text="0" FontSize="10" Height="22"/>
                                <TextBox x:Name="TxtT1Y" Text="100" FontSize="10" Height="22" Margin="0,2,0,0"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="В2" FontSize="10" HorizontalAlignment="Center"/>
                                <TextBox x:Name="TxtT2X" Text="50" FontSize="10" Height="22"/>
                                <TextBox x:Name="TxtT2Y" Text="0" FontSize="10" Height="22" Margin="0,2,0,0"/>
                            </StackPanel>

                            <StackPanel Grid.Column="4">
                                <TextBlock Text="В3" FontSize="10" HorizontalAlignment="Center"/>
                                <TextBox x:Name="TxtT3X" Text="100" FontSize="10" Height="22"/>
                                <TextBox x:Name="TxtT3Y" Text="100" FontSize="10" Height="22" Margin="0,2,0,0"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Многоугольник -->
                <Border Background="White" Padding="6" Margin="0,0,0,6" BorderBrush="#DDD" BorderThickness="1" CornerRadius="3">
                    <StackPanel>
                        <TextBlock Text="МНОГОУГОЛЬНИК" FontSize="11" FontWeight="Bold"/>
                        <TextBox x:Name="TxtPolyPoints" Text="0,50 30,0 80,0 100,50 50,100" 
                                 FontSize="10" Height="45" TextWrapping="Wrap" Margin="0,3,0,0"/>
                        <TextBlock Text="координаты x1,y1 x2,y2 и тд че" FontSize="11" FontWeight="Bold"/>
                    </StackPanel>
                </Border>

                <!-- Кнопки фигур -->
                <Border Background="White" Padding="6" Margin="0,0,0,6" BorderBrush="#DDD" BorderThickness="1" CornerRadius="3">
                    <StackPanel>
                        <TextBlock Text="ДОБАВИТЬ ФИГУРУ" FontSize="11" FontWeight="Bold" Margin="0,0,0,5"/>
                        <WrapPanel>
                            <Button Content="Прямоугольник" Click="AddRectangle_Click" FontSize="10" Height="26" Margin="0,0,3,3" Padding="8,2"/>
                            <Button Content="Квадрат" Click="AddSquare_Click" FontSize="10" Height="26" Margin="0,0,3,3" Padding="8,2"/>
                            <Button Content="Эллипс" Click="AddEllipse_Click" FontSize="10" Height="26" Margin="0,0,3,3" Padding="8,2"/>
                            <Button Content="Окружность" Click="AddCircle_Click" FontSize="10" Height="26" Margin="0,0,3,3" Padding="8,2"/>
                            <Button Content="Треугольник" Click="AddTriangle_Click" FontSize="10" Height="26" Margin="0,0,3,3" Padding="8,2"/>
                            <Button Content="Многоугольник" Click="AddPolygon_Click" FontSize="10" Height="26" Margin="0,0,3,3" Padding="8,2"/>
                            <Button Content="Машина" Click="AddCar_Click" FontSize="10" Height="26" Margin="0,0,3,3" Padding="8,2"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <!-- Список фигур -->
                <Border Background="White" Padding="6" Margin="0,0,0,6" BorderBrush="#DDD" BorderThickness="1" CornerRadius="3">
                    <StackPanel>
                        <TextBlock Text="СПИСОК ФИГУР" FontSize="11" FontWeight="Bold"/>
                        <ListBox x:Name="LstFigures" Height="90" FontSize="10" Margin="0,4,0,4"/>
                        <WrapPanel>
                            <Button Content="Удалить" Click="DeleteFigure_Click" FontSize="10" Height="26" Width="70" Margin="0,0,5,0" Padding="5,2"/>
                            <Button Content="Очистить всё" Click="ClearAll_Click" FontSize="10" Height="26" Width="80" Padding="5,2"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
        <Border Grid.Column="1" Margin="8" BorderBrush="Gray" BorderThickness="2" Background="White" CornerRadius="3">
            <Grid>
                <Image x:Name="DrawingImage" Stretch="Uniform"/>
            </Grid>
        </Border>
        <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto" Background="#F5F5F5">
            <StackPanel Margin="8">
                <Border Background="White" Padding="8" Margin="0,0,0,8" BorderBrush="#DDD" BorderThickness="1" CornerRadius="3">
                    <StackPanel>
                        <TextBlock Text="УПРАВЛЕНИЕ ФИГУРОЙ" FontSize="12" FontWeight="Bold" Margin="0,0,0,8"/>
                        <TextBlock Text="Выберите фигуру в списке" FontSize="10" Foreground="Gray" Margin="0,0,0,8"/>
                        <TextBlock Text="Для круга:" FontSize="10" FontWeight="SemiBold" Margin="0,5,0,3"/>
                        <Grid Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Радиус:" Grid.Column="0" FontSize="10" VerticalAlignment="Center" Margin="0,0,5,0"/>
                            <TextBox x:Name="TxtNewRadius" Grid.Column="1" FontSize="10" Height="24"/>
                        </Grid>
                        <Button Content="Изменить радиус" Click="ChangeRadius_Click" FontSize="10" Height="28" Margin="0,0,0,8" Padding="5,3"/>

                        <TextBlock Text="Для прямоугольника:" FontSize="10" FontWeight="SemiBold" Margin="0,5,0,3"/>
                        <Grid Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Шир:" Grid.Column="0" FontSize="10" VerticalAlignment="Center" Margin="0,0,3,0"/>
                            <TextBox x:Name="TxtNewWidth" Grid.Column="1" FontSize="10" Height="24" Margin="0,0,5,0"/>
                            <TextBlock Text="Выс:" Grid.Column="2" FontSize="10" VerticalAlignment="Center" Margin="0,0,3,0"/>
                            <TextBox x:Name="TxtNewHeight" Grid.Column="3" FontSize="10" Height="24"/>
                        </Grid>
                        <Button Content="Изменить размер" Click="ResizeRectangle_Click" FontSize="10" Height="28" Margin="0,0,0,8" Padding="5,3"/>

                        <TextBlock Text="Перемещение:" FontSize="10" FontWeight="SemiBold" Margin="0,5,0,3"/>
                        <Grid Margin="0,0,0,5">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Δx:" Grid.Column="0" FontSize="10" VerticalAlignment="Center" Margin="0,0,3,0"/>
                            <TextBox x:Name="TxtDeltaX" Grid.Column="1" Text="10" FontSize="10" Height="24" Margin="0,0,5,0"/>
                            <TextBlock Text="Δy:" Grid.Column="2" FontSize="10" VerticalAlignment="Center" Margin="0,0,3,0"/>
                            <TextBox x:Name="TxtDeltaY" Grid.Column="3" Text="10" FontSize="10" Height="24"/>
                        </Grid>
                        <Button Content="Переместить фигуру" Click="MoveFigure_Click" FontSize="10" Height="28" Margin="0,0,0,8" Padding="5,3"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>